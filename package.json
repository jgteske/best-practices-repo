{
  "name": "best-practices-repo",
  "version": "1.0.0",
  "private": true,
  "description": "General documentation repository built with VitePress, featuring an in-depth TypeScript Best Practices guide.",
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "npm run typecheck && npm run docs:build"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "mermaid": "^11.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vitepress": "^1.3.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
